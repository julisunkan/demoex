# ================================================================================
#  Financial Data Analyzer — Environment Variables Reference
#  Copy this file to .env for local development (never commit .env to Git)
# ================================================================================

# ── Azure App Registration ────────────────────────────────────────────────────
# Required for Microsoft Graph access (email backup, restore, analytics).
# Create an app registration in the Azure portal:
#   https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Grant these delegated Graph permissions: Mail.Read, Mail.ReadWrite, User.Read
# Add your Replit preview URL as a Single-Page Application redirect URI.

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Backend: Admin Panel ──────────────────────────────────────────────────────
# Protects the /admin route. Use a strong, randomly generated password.
# Recommendation: openssl rand -base64 24

ADMIN_PASSWORD=

# ── Backend: Session Security ─────────────────────────────────────────────────
# Long random string used to sign session cookies.
# Generate with: openssl rand -base64 32

SESSION_SECRET=

# ── Backend: CORS ─────────────────────────────────────────────────────────────
# Your frontend URL. In development this is optional (all origins allowed).
# In production (NODE_ENV=production) only this origin is accepted.
# Example: https://financial-data-analyzer-app.onrender.com

FRONTEND_URL=

# ── Backend: Email Notifications (optional) ───────────────────────────────────
# Required only if you enable subscription renewal reminder emails in /admin.
# Leave blank to disable all email features.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Frontend (Vite): API URL ──────────────────────────────────────────────────
# Full URL of the backend API. Leave empty in development — Vite's proxy
# forwards /api/* to localhost:3001 automatically.
# In production set this to your deployed backend URL.
# Example: https://financial-data-analyzer-api.onrender.com

VITE_API_URL=

# ── Frontend (Vite): Azure AD ─────────────────────────────────────────────────
# REQUIRED — your Azure app registration's Application (client) ID.
# This enables MSAL to acquire a Microsoft Graph token inside the add-in.
# Use "common" for TENANT_ID to allow both personal and work/school accounts.

VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common

# ── Development Only ──────────────────────────────────────────────────────────
# API_PORT is only used locally if you want to run the backend on a different
# port than 3001. Render sets PORT automatically.

API_PORT=3001
